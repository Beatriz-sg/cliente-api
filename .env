# URL base da API backend
# Emulador Android (AVD): use 10.0.2.2 para apontar para localhost da máquina
# Dispositivo físico / Expo Go: use o IP da sua máquina na rede local (ex: 192.168.1.10)
# Produção: use a URL do servidor

# Dispositivo físico / Expo Go
EXPO_PUBLIC_API_URL=http://localhost:8080

# Emulador Android (AVD) -> 10.0.2.2 aponta para localhost da máquina host
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
